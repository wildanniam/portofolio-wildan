{
  "name": "portofolio-wildan",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25",
    "npm": ">=11.0.0 <12"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test tests/e2e --grep-invert @a11y",
    "test:a11y": "playwright test tests/e2e --grep @a11y",
    "analyze:runtime": "node scripts/analyze-runtime-fixture.mjs",
    "analyze:bundle": "npm run build && node scripts/analyze-bundle-matrix.mjs",
    "lighthouse": "npm ci --prefix tools/lighthouse && npm audit --prefix tools/lighthouse --audit-level=high && node scripts/run-lighthouse.mjs",
    "quality:static": "npm run lint && npm run typecheck && npm run test:run",
    "shadcn": "shadcn"
  },
  "allowScripts": {
    "@tailwindcss/oxide@4.1.13": true,
    "@vercel/speed-insights@1.2.0": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.11.1": true
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/render": "^1.3.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.22",
    "gsap": "^3.13.0",
    "lucide-react": "^0.544.0",
    "motion": "^12.23.22",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-bits": "^1.0.5",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.63.0",
    "resend": "^6.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "three": "^0.184.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "24.13.3",
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.11",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
